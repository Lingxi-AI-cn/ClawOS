{
  "name": "clawos-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "pnpm build:electron-ts && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:electron-ts": "tsc -p electron/tsconfig.json",
    "build": "tsc -b && vite build",
    "build:all": "pnpm build:electron-ts && pnpm build",
    "build:package": "pnpm build:all && electron-builder",
    "cap:sync": "npx cap sync android",
    "cap:build": "pnpm build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "cap:open": "npx cap open android",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron"
    ]
  },
  "dependencies": {
    "@capacitor/core": "^7.5.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "lucide-react": "^0.563.0",
    "motion": "^12.34.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.182.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^7.5.0",
    "@capacitor/cli": "^7.5.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.3"
  }
}
