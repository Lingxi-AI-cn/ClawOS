# ClawOS AOSP 构建环境配置
# 复制为 .env.local 并修改为你的实际路径：
#   cp env.example .env.local
#
# .env.local 已在 .gitignore 中，不会被提交。

# ── 项目路径 ──────────────────────────────────────────────────
CLAWOS_ROOT=/path/to/ClawOS
AOSP_DIR=/path/to/aosp
AOSP16_DIR=/path/to/aosp16

# ── JDK (Gradle 构建需要) ────────────────────────────────────
JAVA_HOME=/path/to/jdk-21

# ── Linux 构建服务器 (Mac/Windows 拉取镜像 / 模拟器脚本使用) ──
LINUX_USER=your-username
LINUX_HOST=your-build-server
LINUX_PORT=22

# 局域网模式 (--lan 参数时使用)
LINUX_LAN_HOST=your-build-server-lan-hostname
LINUX_LAN_PORT=22

# ── SourceForge (ROM 发布) ────────────────────────────────────
SF_USER=your-sf-username
SF_PROJECT=clawos

# ── Mac 端 (镜像传输目标) ────────────────────────────────────
MAC_USER=your-username
MAC_IMAGE_DIR=~/clawos-emulator-images
